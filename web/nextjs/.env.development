# Used by `next dev` (:3340) so EventSource hits Hono (:7340) directly.
# Reason: Next.js dev rewrites buffer text/event-stream responses, so SSE
# never reaches the browser through /api/* — the static export served by
# Hono itself leaves this unset and uses same-origin /api.
NEXT_PUBLIC_RELAY_API=http://127.0.0.1:7340
